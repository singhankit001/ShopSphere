# ── Node / NPM ───────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.yarn/

# ── Build outputs (built fresh inside container) ─────────────────
client/dist/
client/build/
server/build/
.cache/

# ── Environment & Secrets (NEVER bake into images) ───────────────
.env
.env.*
!.env.example
client/.env
client/.env.*
server/.env
server/.env.*

# ── VCS ──────────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ── Editor / OS artifacts ────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ── Test & CI artifacts ──────────────────────────────────────────
coverage/
.nyc_output/
*.test.js
*.spec.js
__tests__/
.github/

# ── DevOps tooling (not needed in runtime image) ─────────────────
scripts/
docker-compose*.yml
.aws/

# ── Database dumps ───────────────────────────────────────────────
db_data/
*.sql
*.dump

# ── Docs ─────────────────────────────────────────────────────────
*.md
LICENSE
